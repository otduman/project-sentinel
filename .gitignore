# ============================================================
# Project Sentinel — Root .gitignore
# ============================================================

# --- Secrets (NEVER commit) ---
.env
.env.local
.env.*.local

# --- Gradle (root-level cache and build) ---
.gradle/
build/

# --- Java build artifacts ---
*.jar
!gradle/wrapper/gradle-wrapper.jar

# --- IDE — IntelliJ IDEA ---
.idea/
*.iml
*.iws
*.ipr
out/

# --- Logs ---
*.log
*.log.*.gz
application.log

# --- OS ---
.DS_Store
Thumbs.db

# --- Profiler temp output ---
sentinel-profiler-*.txt
