# Copy this file to .env and fill in your values.

GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL credentials (used by sentinel-agent and the postgres container)
DB_USERNAME=sentinel
DB_PASSWORD=changeme_db

# Grafana admin credentials
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme_grafana

# Activate Postgres profile (optional, H2 is default)
# SPRING_PROFILES_ACTIVE=postgres
